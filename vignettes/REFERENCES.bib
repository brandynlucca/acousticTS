@article{rudgers_acoustic_1969,
	title = {Acoustic {Pulses} {Scattered} by a {Rigid} {Sphere} {Immersed} in a {Fluid}},
	volume = {45},
	issn = {0001-4966, 1520-8524},
	url = {https://pubs.aip.org/jasa/article/45/4/900/756071/Acoustic-Pulses-Scattered-by-a-Rigid-Sphere},
	doi = {10.1121/1.1911567},
	abstract = {The scattered field, produced when a plane-wave pressure pulse is incident upon an ideally rigid sphere, is expressed in the terms of classical scattering theory. Using an incident pulse of known spectral content, the resultant scattered pulse is determined, at a number of field points, with a computer. The time-varying forms of the scattered pulses, thus obtained using the completely rigorous classical theory, display characteristics that may be interpreted in terms of circumferential or creeping waves propagating along the periphery of the sphere. The scattered pulse may be conceived as the superposition of a specularly reflected pulse, with a form similar to the incident pulse, and attenuating pulses that travel along the periphery of the sphere from the boundary of the geometrical shadow to the observation point.},
	language = {en},
	number = {4},
	urldate = {2026-03-27},
	journal = {The Journal of the Acoustical Society of America},
	author = {Rudgers, Anthony J.},
	month = apr,
	year = {1969},
	pages = {900--910},
}

